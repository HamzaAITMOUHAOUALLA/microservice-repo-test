# ================= GLOBAL =================

IMAGE_NAME=data-demo-api
IMAGE_TAG=1.0.0

CONTAINER_NAME=data-demo-api-staging
STAGING_PORT=8080

# ================= HARBOR =================

HARBOR_REGISTRY=harbor.company.local
HARBOR_PROJECT=microservices

# ================= TEMPLATE =================

TEMPLATE_REPO=github.com/company/pipeline-template
