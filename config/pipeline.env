# ================= GITOPS =================

GITOPS_REPO=github.com/company/gitops
GITOPS_PATH=apps

# ================= SOURCE =================

SOURCE_REPO=github.com/company/data-demo-api
SOURCE_BRANCH=main

# ================= APPLICATION =================

APP_PORT=8080